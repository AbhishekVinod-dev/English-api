{
  "manifest_version": 3,
  "name": "English api",
  "version": "1.0",
  "description": "Silently enhances browsing with instant, elegant word definitions.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "LexiScan Pro"
  }
}